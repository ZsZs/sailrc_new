    "@angular/compiler-cli": "~19.2.7",
    "@angular/language-service": "~19.2.4",
    "@eslint/js": "^9.23.0",
    "@nx/angular": "20.7.0",
    "@nx/devkit": "20.7.0",
    "@nx/eslint": "20.7.0",
    "@nx/eslint-plugin": "20.7.0",
