{
  "name": "sailrc",
  "version": "0.0.1",
  "license": "MIT",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZsZs/sailrc_new.git",
    "directory": "apps/sailrc"
  },
  "homepage": "https://github.com/ZsZs/sailrc_new#readme",
  "scripts": {
    "config-env-sailrc": "ts-node apps/sailrc/src/assets/setEnv.ts",
    "run-firebase-emulator": "firebase emulators:start",
    "serve-sailrc": "npm run config-env-sailrc -- --environment=dev && nx run sailrc:serve --configuration=de-DE",
    "playwright-codeget": "npx playwright codegen http://localhost:4200",
    "lint-sailrc": "nx run sailrc:lint --configuration=ci --no-cloud",
    "test-sailrc": "nx run sailrc:test --configuration=ci --coverage --no-cloud",
    "e2e-test-sailrc": "nx e2e sailrc-e2e --no-cloud",
    "build-sailrc": "nx run sailrc:build --configuration=production --no-cloud"
  },
  "dependencies": {
